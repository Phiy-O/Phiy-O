<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lampu | JavaScript</title>
</head>
<body>
    <h1><center>LAMPU SWITCHER</center></h1>
    <center><img src="Images/off.gif" alt="" id="lampu1"/></center>
    <center>
        <button onclick="saklar('on')">Turn on</button>
        <button onclick="saklar('off')">Turn off</button>
    </center>

    <!-- Script Js -->
    <script>
        function saklar(params) {
            console.log(params);

            let lampu1 = document.getElementById("lampu1");

            if (params == "on"){
                lampu1.src = "Images/on.gif"
            }
            if (params == "off"){
                lampu1.src = "Images/off.gif"
            }
            return lampu1
        }
    </script>
</body>
</html>
